    <Target Name="DeduplicateReferencePath" BeforeTargets="ResolveReferences">
      <!-- 1. Project ReferencePath to filenames -->
      <ItemGroup>
          <_RefFileName Include="@(ReferencePath->'%(Filename)%(Extension)')"
                        Condition="'%(WinMDFile)' == 'true'"
                        Original="%(ReferencePath.Identity)" />
      </ItemGroup>
      <!-- 2. Remove duplicates based on filename -->
      <RemoveDuplicates Inputs="@(_RefFileName)">
        <Output TaskParameter="Filtered" ItemName="_UniqueRefFileName" />
      </RemoveDuplicates>
      <!-- 3. Reconstruct the deduped ReferencePath list -->
      <ItemGroup>
        <ReferencePath Remove="@(ReferencePath)" />
        <ReferencePath Include="@(_UniqueRefFileName->'%(Original)')" />
      </ItemGroup>
    </Target>
